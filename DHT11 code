  Serial.println(" %"); 
  // Door Logic (LED) 
  if (temperature > tempThreshold || humidity > humThreshold) { 
    digitalWrite(LEDPIN, HIGH); 
    Serial.println("Door Status: OPEN (LED ON)"); 
  } else { 
    digitalWrite(LEDPIN, LOW); 
    Serial.println("Door Status: CLOSED (LED OFF)"); 
  } 
